# ============================================================
#  KONFIGURASI APLIKASI
#  Salin file ini menjadi ".env" lalu isi sesuai kebutuhan.
# ============================================================

# Port server (default 3000)
PORT=3000

# Password untuk masuk ke halaman Admin (/admin)
ADMIN_PASSWORD=admin123

# Kunci rahasia untuk session login admin (ganti dengan teks acak)
SESSION_SECRET=ganti-dengan-teks-rahasia-acak

# Nomor WhatsApp admin penerima bukti. Format: 628xxxxxxxxxx
ADMIN_PHONE=6281234567890

# (Opsional) Payload QRIS merchant. Kosong = QR berisi ringkasan pesanan.
QRIS_PAYLOAD=

# ============================================================
#  DATABASE - MariaDB / MySQL (RDS)
#  Tabel dibuat otomatis saat aplikasi pertama jalan.
# ============================================================
DB_HOST=nama-endpoint.xxxxxx.ap-southeast-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=
DB_NAME=idn

# ============================================================
#  PENYIMPANAN BUKTI PEMBAYARAN - Amazon S3
#  Cukup isi NAMA BUCKET-nya. Buat bucket di S3, lalu tulis
#  namanya di sini - selesai. Kosongkan kalau mau simpan lokal.
#  Di EC2, kredensial diambil otomatis dari IAM Role instance.
# ============================================================
S3_BUCKET=
AWS_REGION=ap-southeast-1

# ============================================================
#  EMAIL (Opsional)
#  Kosong = isi email hanya dicetak di terminal.
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ID-Networkers <no-reply@idn.id>
ADMIN_EMAIL=admin@idn.id
