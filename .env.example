# ============================================================
#  KONFIGURASI APLIKASI
#  Salin file ini menjadi ".env" lalu isi sesuai kebutuhan.
#  Aplikasi tetap jalan walau sebagian dibiarkan kosong.
# ============================================================

# Port server (default 3000)
PORT=3000

# Password untuk masuk ke halaman Admin (/admin)
ADMIN_PASSWORD=admin123

# Kunci rahasia untuk session login admin (ganti dengan teks acak)
SESSION_SECRET=ganti-dengan-teks-rahasia-acak

# Nomor WhatsApp admin untuk menerima bukti pembayaran.
# Format internasional tanpa tanda "+" atau "0" di depan.
# Contoh nomor 0812-3456-7890 ditulis: 6281234567890
ADMIN_PHONE=6281234567890

# (Opsional) Teks payload QRIS milik merchant kamu.
# Kalau dikosongkan, QR akan berisi ringkasan pendaftaran saja.
QRIS_PAYLOAD=

# ============================================================
#  EMAIL (Opsional)
#  Diisi kalau ingin mengirim konfirmasi lewat email.
#  Kalau dikosongkan, isi email hanya dicetak di terminal.
#  Contoh untuk Gmail: gunakan "App Password", bukan password biasa.
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ID-Networkers <no-reply@idn.id>
ADMIN_EMAIL=admin@idn.id
